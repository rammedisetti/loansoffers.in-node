# Server configuration
PORT=4000
# Session secret — change this to a long random string in production
SESSION_SECRET=change-me-to-a-long-random-secret
# Comma-separated list of allowed CORS origins (React dev server and/or production domain)
CLIENT_ORIGIN=http://localhost:5173
# Google Tag Manager container ID (optional, e.g. GTM-XXXXXXX). Leave blank to disable.
GTM_ID=
# Default staff credentials seeded on first run
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Blog author display defaults
BLOG_AUTHOR_NAME=loansoffers.in Team
BLOG_AUTHOR_AVATAR=
# Set to "production" behind HTTPS to enable secure cookies
NODE_ENV=development
