# Production server configuration for https://loansoffers.in/
# Copy to server/.env on the Hostinger server and fill in the secrets.
PORT=4000
SESSION_SECRET=replace-with-a-long-random-secret
CLIENT_ORIGIN=https://loansoffers.in
GTM_ID=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
BLOG_AUTHOR_NAME=loansoffers.in Team
BLOG_AUTHOR_AVATAR=
NODE_ENV=production
