{
  "name": "loansoffers",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",

    "server": "node --watch src/index.js",

    "client": "npm --prefix client run dev",

    "build": "npm --prefix client run build",

    "start": "node src/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express-session": "^1.18.0",
    "connect-sqlite3": "^0.9.17",
    "sqlite3": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "multer": "^2.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}